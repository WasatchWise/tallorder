{
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm run build --filter=tall-order",
  "ignoreCommand": "npx turbo-ignore tall-order",
  "crons": [
    {
      "path": "/api/cron/sunday-availability-nudge",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/weekly-token-refill",
      "schedule": "0 14 * * 1"
    }
  ]
}
